{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*\\.js)",
      "destination": "/public/$1"
    },
    {
      "source": "/(.*\\.css)",
      "destination": "/public/$1"
    },
    {
      "source": "/(.*\\.html)",
      "destination": "/public/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/public/$1"
    }
  ]
}
